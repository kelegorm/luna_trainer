  "fixed_sql": [
    {
      "name": "sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sessions\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"mode\" TEXT NOT NULL, \"started_at\" INTEGER NOT NULL, \"ended_at\" INTEGER NULL, \"outcome_json\" TEXT NULL, \"difficulty_band\" INTEGER NOT NULL DEFAULT 2, \"user_adjusted\" INTEGER NOT NULL DEFAULT 0 CHECK (\"user_adjusted\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "move_events",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"move_events\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"session_id\" INTEGER NOT NULL REFERENCES sessions (id) ON DELETE CASCADE, \"kind_id\" TEXT NOT NULL, \"heuristic_tag\" TEXT NOT NULL, \"latency_ms\" INTEGER NOT NULL, \"was_correct\" INTEGER NOT NULL CHECK (\"was_correct\" IN (0, 1)), \"hint_requested\" INTEGER NOT NULL CHECK (\"hint_requested\" IN (0, 1)), \"hint_step_reached\" INTEGER NOT NULL DEFAULT 0, \"contaminated_flag\" INTEGER NOT NULL CHECK (\"contaminated_flag\" IN (0, 1)), \"idle_soft_signal\" INTEGER NOT NULL CHECK (\"idle_soft_signal\" IN (0, 1)), \"motion_signal\" INTEGER NOT NULL CHECK (\"motion_signal\" IN (0, 1)), \"lifecycle_signal\" INTEGER NOT NULL CHECK (\"lifecycle_signal\" IN (0, 1)), \"mode\" TEXT NULL, \"event_kind\" TEXT NOT NULL DEFAULT 'production', \"chain_index\" INTEGER NOT NULL DEFAULT 0, \"difficulty_band\" INTEGER NOT NULL DEFAULT 2, \"user_adjusted\" INTEGER NOT NULL DEFAULT 0 CHECK (\"user_adjusted\" IN (0, 1)), \"created_at\" INTEGER NOT NULL);"
        }
      ]
    },
    {
      "name": "mastery_state",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"mastery_state\" (\"kind_id\" TEXT NOT NULL, \"heuristic_tag\" TEXT NOT NULL, \"event_count\" INTEGER NOT NULL DEFAULT 0, \"ewma_percentile\" REAL NOT NULL DEFAULT 0.0, \"outlier_count\" INTEGER NOT NULL DEFAULT 0, \"latency_p25_ms\" INTEGER NULL, \"latency_median_ms\" INTEGER NULL, \"latency_p75_ms\" INTEGER NULL, \"error_rate\" REAL NOT NULL DEFAULT 0.0, \"hint_rate\" REAL NOT NULL DEFAULT 0.0, \"hint_step_counts_json\" TEXT NOT NULL DEFAULT '{}', \"last_updated_at\" INTEGER NOT NULL, \"is_calibrating\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_calibrating\" IN (0, 1)), PRIMARY KEY (\"kind_id\", \"heuristic_tag\"));"
        }
      ]
    },
    {
      "name": "fsrs_cards",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"fsrs_cards\" (\"kind_id\" TEXT NOT NULL, \"heuristic_tag\" TEXT NOT NULL, \"state_blob\" BLOB NOT NULL, \"due_at\" INTEGER NOT NULL, \"last_reviewed_at\" INTEGER NULL, PRIMARY KEY (\"kind_id\", \"heuristic_tag\"));"
        }
      ]
    }
  ]
